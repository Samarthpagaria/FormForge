# FormForge — environment variables (copy to `.env` at repo root)

# Database
DATABASE_URL=

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=

# App URL (used in emails)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Resend — sandbox for local development
# Delivers only to the email on your Resend account when using onboarding@resend.dev
RESEND_API_KEY=
RESEND_FROM=FormForge <onboarding@resend.dev>
