    "/responses.submit": {
      "post": {
        "tags": [
          "Responses"
        ],
        "summary": "Submit a form response (public)",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "formId": {
                    "type": "string"
                  },
                  "formVersionId": {
                    "type": "string"
                  },
                  "sessionId": {
                    "type": "string"
                  },
                  "answers": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "fieldKey": {
                          "type": "string"
                        },
                        "value": {}
                      }
                    }
                  },
                  "meta": {
                    "type": "object",
                    "properties": {
                      "ip": {
                        "type": "string"
                      },
                      "userAgent": {
                        "type": "string"
                      },
                      "device": {
                        "type": "string",
                        "enum": [
                          "desktop",
                          "mobile",
                          "tablet"
                        ]
                      },
                      "browser": {
                        "type": "string"
                      },
                      "os": {
                        "type": "string"
                      },
                      "completionTime": {
                        "type": "number"
                      }
                    }
                  }
                },
                "required": [
                  "formId",
                  "formVersionId",
                  "answers"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Submission recorded"
          },
          "403": {
            "description": "Form not active"
          },
          "409": {
            "description": "Already submitted"
          }
        }
      }
    },
