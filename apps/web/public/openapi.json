{
  "openapi": "3.0.0",
  "info": {
    "title": "FormForge API",
    "version": "1.0.0",
    "description": "The FormForge REST API allows developers to programmatically create forms, collect responses, and track analytics."
  },
  "servers": [
    {
      "url": "http://localhost:3000/api/trpc",
      "description": "Development"
    }
  ],
  "tags": [
    {
      "name": "Forms",
      "description": "Create and manage forms"
    },
    {
      "name": "Responses",
      "description": "Submit and retrieve form responses"
    },
    {
      "name": "Analytics",
      "description": "Track and analyze form performance"
    },
    {
      "name": "Templates",
      "description": "Use and manage form templates"
    },
    {
      "name": "Share",
      "description": "Share forms via links and QR codes"
    },
    {
      "name": "Form Versions",
      "description": "Manage form version history"
    }
  ],
  "paths": {
    "/forms.create": {
      "post": {
        "tags": [
          "Forms"
        ],
        "summary": "Create a new form",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 100
                  },
                  "description": {
                    "type": "string",
                    "maxLength": 1000
                  }
                },
                "required": [
                  "name"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Form created successfully"
          },
          "401": {
            "description": "Unauthorized"
          },
          "500": {
            "description": "Internal server error"
          }
        }
      }
    },
    "/forms.getAllForms": {
      "get": {
        "tags": [
          "Forms"
        ],
        "summary": "Get all forms for authenticated user",
        "security": [
